# Normalize all text files to LF in the repo; no conversion on checkout.
# This prevents CRLF/LF churn on Windows (core.autocrlf noise).
* text=auto eol=lf

# Explicitly mark binary files so Git never attempts line-ending conversion.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.otf  binary
*.zip  binary
*.gz   binary
